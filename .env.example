# ─────────────────────────────────────────────
# Configuración de Jira Time Logger
# ─────────────────────────────────────────────
# Copia este archivo a .env y completa los valores.
# NUNCA subas el archivo .env a Git.

# URL de tu instancia Jira
JIRA_SITE_URL=https://apvf2021.atlassian.net

# Tu email de Atlassian
JIRA_EMAIL=jjimenez@accionpoint.com

# API Token de Jira
# Generalo en: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=PEGA_AQUI_TU_TOKEN_DE_JIRA
